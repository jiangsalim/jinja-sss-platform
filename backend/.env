APP_NAME=Jinja SSS Platform
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
PORT=8000
HOST=0.0.0.0
SECRET_KEY=jss-dev-secret-change-in-production
JWT_SECRET_KEY=jss-jwt-dev-secret-change-in-production
