<!-- ============================================
     JINJA SSS PLATFORM - FLOATING GRID MENU
     Expandable floating action button menu
     ============================================ -->

<style>
.jss-float-menu {
    position: fixed;
    bottom: var(--spacing-xl);
    right: var(--spacing-xl);
    z-index: var(--z-tooltip);
    display: grid;
    grid-template-columns: 0rem 3.5rem 0rem;
    grid-template-rows: 0rem 3.5rem 0rem;
    gap: 0;
    overflow: hidden;
    transition: gap 0.4s ease 0s, grid-template-columns 0.4s ease 0.6s, grid-template-rows 0.4s ease 0.6s;
    place-items: center;
}
.jss-float-menu:hover, .jss-float-menu--open {
    grid-template-columns: 3.5rem 3.5rem 3.5rem;
    grid-template-rows: 3.5rem 3.5rem 3.5rem;
    gap: 0.6rem;
    overflow: visible;
    transition: grid-template-columns 0.4s ease 0s, grid-template-rows 0.4s ease 0.5s, gap 0.4s ease 0s;
}
.jss-float-menu__item {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    cursor: pointer;
    border: none;
    color: white;
    box-shadow: var(--shadow-lg);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
}
.jss-float-menu__item:hover {
    transform: scale(1.1);
    box-shadow: var(--shadow-xl);
}
.jss-float-menu__item--primary { background: var(--primary-blue); }
.jss-float-menu__item--success { background: var(--success); }
.jss-float-menu__item--warning { background: var(--warning); color: #333; }
.jss-float-menu__item--error { background: var(--error); }
.jss-float-menu__item--info { background: var(--info); }
.jss-float-menu__item--accent { background: var(--primary-purple); }
.jss-float-menu__item--dark { background: #343a40; }
.jss-float-menu__item--center {
    background: var(--primary-blue);
    font-size: 1.6rem;
    font-weight: bold;
    z-index: 2;
}
@media (max-width: 767px) {
    .jss-float-menu { bottom: 90px; right: var(--spacing-md); }
}
</style>

<div class="jss-float-menu" id="floatMenu" role="navigation" aria-label="Quick actions menu">
    <a href="#" class="jss-float-menu__item jss-float-menu__item--success" title="Grades" style="grid-column:1;grid-row:1;">📊</a>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--info" title="Messages" style="grid-column:2;grid-row:1;">💬</a>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--accent" title="AI Assistant" style="grid-column:3;grid-row:1;">🤖</a>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--warning" title="Assignments" style="grid-column:1;grid-row:2;">📝</a>
    <button class="jss-float-menu__item jss-float-menu__item--center" title="Menu" style="grid-column:2;grid-row:2;" onclick="document.getElementById('floatMenu').classList.toggle('jss-float-menu--open')">+</button>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--dark" title="Calendar" style="grid-column:3;grid-row:2;">📅</a>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--error" title="Report Issue" style="grid-column:1;grid-row:3;">🚨</a>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--primary" title="Settings" style="grid-column:2;grid-row:3;">⚙️</a>
    <a href="#" class="jss-float-menu__item jss-float-menu__item--success" title="Help" style="grid-column:3;grid-row:3;">❓</a>
</div>

